

model Specialty{
  id String @id @default(uuid(7))

  title String @unique @db.VarChar(100)
  description String? @db.Text
  icon String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updated DateTime @updatedAt

  isDeleted Boolean @default(false)
  deletedAt DateTime?

  @@index([isDeleted],name: "idx_specialty_isDeleted") //This makes filtering deleted vs non-deleted data much faster.
  @@index([title], name:"idx_specialty_title")
  @@map("specialties") // In the database, this table name will be specialties, not Specialty.
}